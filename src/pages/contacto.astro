---
/**
 * Contacto — Masecor Web
 *
 * Layout minimalista con WhatsApp como CTA principal.
 * FAQ con diseño elegante de líneas separadoras.
 */

import Layout from '../layouts/Layout.astro';
import BackToCatalog from '../components/BackToCatalog.astro';
import {
  COMPANY_INFO,
  SOCIAL_LINKS,
  getWhatsAppUrl,
  WHATSAPP_CONFIG,
} from '../utils/constants';

const whatsappUrl = getWhatsAppUrl(WHATSAPP_CONFIG.defaultMessage);
const mapsEmbedUrl = `https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3406.14!2d${COMPANY_INFO.mapsLng}!3d${COMPANY_INFO.mapsLat}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x943297003ba9e8db%3A0x908f46b1780c84bc!2sEco%20Parque%20Industrial%20Cordoba!5e0!3m2!1ses-419!2sar!4v1718300000000!5m2!1ses-419!2sar`;
---

<Layout
  title="Contacto"
  description="Contactanos por WhatsApp para consultas, cotizaciones y pedidos. Masecor — Fábrica de acero inoxidable."
>
  <main>
    <!-- Header -->
    <section class="page-header section section--dark">
      <div class="container">
        <span class="eyebrow" data-reveal="fade">Contacto</span>
        <h1 class="page-header__title steel-shimmer" data-reveal data-delay="1">
          Hablemos
        </h1>
        <p class="page-header__subtitle" data-reveal data-delay="2">
          Escribinos por WhatsApp para consultas, cotizaciones y pedidos.
        </p>
      </div>
    </section>

    <!-- Contact Info -->
    <section class="section section--elevated">
      <div class="container">
        <div class="contact-layout">
          <!-- Left: WhatsApp Card -->
          <div
            class="contact-card contact-card--whatsapp"
            data-reveal="fade-left"
          >
            <span class="card-eyebrow">Contacto Directo</span>
            <h2>Canal Digital</h2>
            <p>
              Iniciá una consulta con nuestro departamento de atención al
              cliente. Cotizaciones y asesoramiento inmediato en horario
              comercial.
            </p>
            <div class="whatsapp-btn-wrapper">
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--whatsapp-premium"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  ><path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                  ></path></svg
                >
                <span>Chatear por WhatsApp</span>
              </a>
            </div>
          </div>

          <!-- Right: Grid of Cards -->
          <div
            class="contact-grid-wrapper"
            data-reveal="fade-right"
            data-delay="1"
          >
            <!-- Card 1: Phone -->
            <div class="info-card">
              <div class="info-card__icon">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                  ></path></svg
                >
              </div>
              <div class="info-card__content">
                <span class="info-card__label">Teléfono</span>
                <a
                  href={`tel:${COMPANY_INFO.phone.replace(/[^0-9+]/g, '')}`}
                  class="info-card__value">{COMPANY_INFO.phone}</a
                >
              </div>
            </div>

            <!-- Card 2: Email -->
            <div class="info-card">
              <div class="info-card__icon">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                  ></path><polyline points="22,6 12,13 2,6"></polyline></svg
                >
              </div>
              <div class="info-card__content">
                <span class="info-card__label">Email</span>
                <a
                  href={`mailto:${COMPANY_INFO.email}`}
                  class="info-card__value">{COMPANY_INFO.email}</a
                >
              </div>
            </div>

            <!-- Card 3: Location -->
            <div class="info-card">
              <div class="info-card__icon">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                  ></path><circle cx="12" cy="10" r="3"></circle></svg
                >
              </div>
              <div class="info-card__content">
                <span class="info-card__label">Ubicación</span>
                <a
                  href={COMPANY_INFO.mapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="info-card__value">{COMPANY_INFO.address}</a
                >
                <span
                  class="info-card__value-text"
                  style="font-size: 12px; color: var(--gray-500); margin-top: 2px;"
                >
                  {COMPANY_INFO.province}, {COMPANY_INFO.country}
                </span>
              </div>
            </div>

            <!-- Card 4: Shipping/Coverage -->
            <div class="info-card">
              <div class="info-card__icon">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><rect x="1" y="3" width="15" height="13"></rect><polygon
                    points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle
                    cx="5.5"
                    cy="18.5"
                    r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"
                  ></circle></svg
                >
              </div>
              <div class="info-card__content">
                <span class="info-card__label">Cobertura</span>
                <span class="info-card__value-text"
                  >Envíos a las 24 provincias</span
                >
              </div>
            </div>

            <!-- Card 5: Hours -->
            <div class="info-card">
              <div class="info-card__icon">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><circle cx="12" cy="12" r="10"></circle><polyline
                    points="12 6 12 12 16 14"></polyline></svg
                >
              </div>
              <div class="info-card__content">
                <span class="info-card__label">Horario</span>
                <span class="info-card__value-text"
                  >Lunes a viernes, 8:00 a 17:00</span
                >
              </div>
            </div>

            <!-- Card 6: Social Media -->
            <div class="info-card">
              <div class="info-card__icon">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                  ></path></svg
                >
              </div>
              <div class="info-card__content">
                <span class="info-card__label">Redes Sociales</span>
                <div class="info-card__social-links">
                  <a
                    href={SOCIAL_LINKS.instagram}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="social-link-premium">Instagram</a
                  >
                  <span class="social-separator">•</span>
                  <a
                    href={SOCIAL_LINKS.facebook}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="social-link-premium">Facebook</a
                  >
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Map Section -->
    <section class="section section--dark map-section">
      <div class="container">
        <div class="map-header" data-reveal>
          <span class="eyebrow">Ubicación</span>
          <h2>Dónde encontrarnos</h2>
          <p class="map-subtitle">
            {COMPANY_INFO.address}, {COMPANY_INFO.province}, {
              COMPANY_INFO.country
            }
          </p>
        </div>
        <div class="map-wrapper" data-reveal data-delay="1">
          <iframe
            src={mapsEmbedUrl}
            width="100%"
            height="400"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de Masecor en Google Maps"></iframe>
          <a
            href={COMPANY_INFO.mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="map-link"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
              ></path><circle cx="12" cy="10" r="3"></circle></svg
            >
            Abrir en Google Maps
          </a>
        </div>
      </div>
    </section>

    <BackToCatalog />
  </main>
</Layout>

<style>
  .page-header {
    position: relative;
    padding-top: 10rem;
    padding-bottom: var(--section-py-sm);
    background-image: url('/images/bg/MAN_5721-scaled.webp');
    background-size: cover;
    background-position: center;
    background-attachment: scroll;
  }

  @media (min-width: 1024px) {
    .page-header {
      background-attachment: fixed;
    }
  }

  .page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    z-index: 0;
  }

  .page-header .container {
    position: relative;
    z-index: 1;
  }

  .page-header__title {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: var(--weight-black);
    color: var(--white);
    letter-spacing: var(--tracking-tighter);
    margin-bottom: var(--space-6);
  }

  .page-header__subtitle {
    font-size: var(--text-lg);
    color: var(--gray-400);
    max-width: 450px;
    margin-bottom: 0;
  }

  /* Contact Layout & Grid */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: stretch;
  }

  @media (min-width: 1024px) {
    .contact-layout {
      grid-template-columns: 0.9fr 1.1fr;
      gap: var(--space-12);
    }
  }

  /* WhatsApp Main Card */
  .contact-card--whatsapp {
    background-color: var(--white);
    border: 1px solid var(--border-light);
    padding: var(--space-8) var(--space-10);
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
  }

  .contact-card--whatsapp::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: var(--color-whatsapp);
  }

  .card-eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    margin-bottom: var(--space-2);
  }

  .contact-card--whatsapp h2 {
    font-size: var(--text-3xl);
    font-weight: var(--weight-extrabold);
    color: var(--black-rich);
    margin-bottom: var(--space-4);
    letter-spacing: var(--tracking-tight);
  }

  .contact-card--whatsapp p {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--gray-600);
    margin-bottom: var(--space-8);
  }

  .whatsapp-btn-wrapper {
    display: flex;
  }

  .btn--whatsapp-premium {
    background-color: var(--color-whatsapp);
    color: var(--white);
    font-weight: var(--weight-semibold);
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    transition: all var(--transition-base);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    font-size: var(--text-xs);
    box-shadow: 0 4px 14px rgba(37, 211, 102, 0.3);
  }

  .btn--whatsapp-premium:hover {
    background-color: var(--color-whatsapp-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.4);
    opacity: 1;
  }

  /* Right Side Info Cards Grid */
  .contact-grid-wrapper {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .contact-grid-wrapper {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4);
    }
  }

  .info-card {
    background-color: var(--white);
    border: 1px solid var(--border-light);
    padding: var(--space-5) var(--space-6);
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    transition: all var(--transition-base);
  }

  .info-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--gray-300);
  }

  .info-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 4px;
    background-color: var(--white-soft);
    border: 1px solid var(--gray-200);
    color: var(--black-rich);
    flex-shrink: 0;
  }

  .info-card__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .info-card__label {
    font-size: 11px;
    font-weight: var(--weight-bold);
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  .info-card__value,
  .info-card__value-text {
    font-size: 14px;
    font-weight: var(--weight-semibold);
    color: var(--black-rich);
    line-height: var(--leading-snug);
    word-break: break-all;
  }

  .info-card__value {
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .info-card__value:hover {
    color: var(--gray-500);
    text-decoration: underline;
  }

  .info-card__social-links {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 14px;
    font-weight: var(--weight-semibold);
  }

  .social-link-premium {
    color: var(--black-rich);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .social-link-premium:hover {
    color: var(--gray-500);
    text-decoration: underline;
  }

  .social-separator {
    color: var(--gray-300);
  }

  /* ── Map Section ── */
  .map-section {
    padding-bottom: 0;
  }

  .map-header {
    margin-bottom: var(--space-10);
  }

  .map-header h2 {
    color: var(--white);
    margin-bottom: var(--space-3);
  }

  .map-subtitle {
    font-size: var(--text-sm);
    color: var(--gray-400);
    margin-bottom: 0;
  }

  .map-wrapper {
    position: relative;
    border: 1px solid var(--gray-800);
    overflow: hidden;
  }

  .map-wrapper iframe {
    display: block;
    width: 100%;
    height: 350px;
    filter: grayscale(0.8) contrast(1.1);
    transition: filter 0.6s var(--ease-out-expo);
  }

  .map-wrapper:hover iframe {
    filter: grayscale(0) contrast(1);
  }

  @media (min-width: 768px) {
    .map-wrapper iframe {
      height: 400px;
    }
  }

  .map-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-5);
    background-color: var(--gray-900);
    border-top: 1px solid var(--gray-800);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--gray-400);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    transition: all 0.3s var(--ease-out-expo);
  }

  .map-link:hover {
    color: var(--white);
    background-color: var(--gray-800);
    opacity: 1;
  }
</style>
