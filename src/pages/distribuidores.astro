---
/**
 * Distribuidores — Masecor Web
 *
 * Página B2B para captación de mayoristas y puntos de venta.
 */

import Layout from '../layouts/Layout.astro';
import BackToCatalog from '../components/BackToCatalog.astro';
import { getWhatsAppUrl, WHATSAPP_CONFIG } from '../utils/constants';

const whatsappUrl = getWhatsAppUrl(WHATSAPP_CONFIG.distributorMessage);
---

<Layout
  title="Red de Distribuidores Masecor"
  description="Sumate a la red de distribuidores de Masecor. Productos de acero inoxidable AISI 304 de alta rentabilidad con envío a todo el país."
>
  <main>
    <section class="page-header section section--dark">
      <div class="container">
        <span class="eyebrow" data-reveal="fade">Oportunidad B2B</span>
        <h1 class="page-header__title steel-shimmer" data-reveal data-delay="1">
          Sumate a nuestra red
        </h1>
        <p class="page-header__subtitle" data-reveal data-delay="2">
          Buscamos aliados comerciales en todo el país. Comercializá productos
          premium de acero inoxidable con excelente margen de rentabilidad.
        </p>
        <div data-reveal data-delay="3" style="margin-top: var(--space-8);">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--primary btn--lg"
          >
            Solicitar Lista de Precios
          </a>
        </div>
      </div>
    </section>

    <!-- Beneficios -->
    <section class="section section--light section--benefits">
      <div class="container">
        <!-- Header + lista -->
        <div class="benefits-header" data-reveal="fade">
          <div class="benefits-header__text">
            <span class="eyebrow">Ventajas</span>
            <h2>Por qué elegir Masecor</h2>
          </div>
          <ul class="benefits-list" role="list">
            <li>
              <strong>Calidad Asegurada:</strong> Productos fabricados 100% en AISI
              304, sin devoluciones por defectos.
            </li>
            <li>
              <strong>Rentabilidad Superior:</strong> Márgenes comerciales competitivos
              para la línea hogar e industrial.
            </li>
            <li>
              <strong>Logística Resuelta:</strong> Entregas semanales a transportes
              con llegada a las 24 provincias.
            </li>
            <li>
              <strong>Atención Personalizada:</strong> Línea directa B2B para reposiciones
              rápidas y pedidos especiales.
            </li>
          </ul>
        </div>

        <!-- Stats row -->
        <div class="stats-row" data-reveal data-delay="2">
          <div class="stat-item">
            <span class="stat-num">24</span>
            <div class="stat-text">
              <strong>Provincias</strong>
              <span>de cobertura nacional</span>
            </div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-num">+35</span>
            <div class="stat-text">
              <strong>Años</strong>
              <span>de fabricación ininterrumpida</span>
            </div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-num">0%</span>
            <div class="stat-text">
              <strong>Fallas</strong>
              <span>por corrosión en acero AISI 304</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pasos -->
    <section class="section section--elevated">
      <div class="container text-center">
        <span class="eyebrow" data-reveal>Proceso simple</span>
        <h2 data-reveal>¿Cómo ser distribuidor?</h2>

        <div class="steps-grid" style="margin-top: var(--space-12);">
          <div class="step-card" data-reveal data-delay="1">
            <div class="step-number">1</div>
            <h3>Contacto Inicial</h3>
            <p>
              Escribinos por WhatsApp indicando el nombre de tu comercio y
              ubicación.
            </p>
          </div>
          <div class="step-card" data-reveal data-delay="2">
            <div class="step-number">2</div>
            <h3>Alta de Cuenta</h3>
            <p>
              Te enviamos los requisitos de facturación y el catálogo con
              precios mayoristas.
            </p>
          </div>
          <div class="step-card" data-reveal data-delay="3">
            <div class="step-number">3</div>
            <h3>Primer Pedido</h3>
            <p>
              Armamos un surtido inicial sugerido de alta rotación para tu zona.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section section--dark text-center">
      <div class="container" data-reveal>
        <h2>Hablemos de negocios</h2>
        <p
          style="max-width: 600px; margin-inline: auto; margin-bottom: var(--space-8); color: var(--gray-400);"
        >
          Contactate con el área mayorista y recibí asesoramiento en el día.
        </p>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--primary btn--lg"
        >
          Contactar por WhatsApp
        </a>
      </div>
    </section>

    <BackToCatalog />
  </main>
</Layout>

<style>
  /* ══════════════════════════════════════════
     PAGE HEADER
  ══════════════════════════════════════════ */
  .page-header {
    position: relative;
    padding-top: clamp(5rem, 4rem + 4vw, 10rem);
    padding-bottom: clamp(2.5rem, 2rem + 2vw, 4rem);
    background-color: var(--black-rich);
    background-image: url('/images/bg/premium_hero_kitchen.webp');
    background-size: cover;
    background-position: center;
    background-attachment: scroll;
  }

  @media (min-width: 768px) {
    .page-header {
      background-attachment: fixed;
    }
  }

  .page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, 0.85);
    z-index: 0;
  }

  .page-header .container {
    position: relative;
    z-index: 1;
  }

  .page-header__title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 2rem + 3vw, var(--text-5xl));
    font-weight: var(--weight-black);
    color: var(--white);
    letter-spacing: var(--tracking-tighter);
    margin-bottom: var(--space-4);
  }

  .page-header__subtitle {
    font-size: clamp(var(--text-sm), 0.875rem + 0.5vw, var(--text-lg));
    color: var(--gray-400);
    max-width: 560px;
    margin-bottom: 0;
  }

  /* ══════════════════════════════════════════
     BENEFICIOS — sección con padding reducido
  ══════════════════════════════════════════ */
  .section--benefits {
    padding-block: clamp(2rem, 1.5rem + 2.5vw, 4rem);
  }

  /* Benefits header: stacked en mobile, 2 cols en tablet+ */
  .benefits-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .benefits-header__text .eyebrow {
    margin-bottom: var(--space-2);
  }

  .benefits-header__text h2 {
    font-size: clamp(var(--text-xl), 1.25rem + 2vw, var(--text-4xl));
    margin-top: 0;
    margin-bottom: 0;
  }

  /* Lista de beneficios */
  .benefits-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .benefits-list li {
    font-size: var(--text-sm);
    color: var(--text-dark-secondary);
    padding-left: var(--space-3);
    border-left: 2px solid var(--gray-200);
    line-height: var(--leading-relaxed);
    transition: border-color 0.3s var(--ease-out-expo);
  }

  .benefits-list li:hover {
    border-left-color: var(--black);
  }

  .benefits-list strong {
    display: inline;
    color: var(--text-dark);
    font-family: var(--font-display);
    font-size: inherit;
    margin-right: 3px;
  }

  @media (min-width: 768px) {
    .benefits-header {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
      align-items: start;
      margin-bottom: var(--space-10);
    }

    .benefits-list {
      gap: var(--space-4);
    }

    .benefits-list li {
      font-size: var(--text-base);
      padding-left: var(--space-4);
    }

    .benefits-list strong {
      display: block;
      margin-right: 0;
      margin-bottom: 2px;
    }
  }

  /* ══════════════════════════════════════════
     STATS ROW — siempre 3 columnas
  ══════════════════════════════════════════ */
  .stats-row {
    background: var(--black);
    border-radius: var(--radius-lg);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    overflow: hidden;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-5) var(--space-2);
    gap: 3px;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }

  .stat-item:last-child {
    border-right: none;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1rem + 2.5vw, var(--text-5xl));
    font-weight: var(--weight-black);
    color: var(--white);
    line-height: 1;
    letter-spacing: var(--tracking-tighter);
  }

  .stat-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .stat-text strong {
    font-size: clamp(0.55rem, 0.4rem + 0.5vw, var(--text-xs));
    font-weight: var(--weight-semibold);
    color: var(--gray-300);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
  }

  .stat-text span {
    font-size: clamp(0.55rem, 0.4rem + 0.5vw, var(--text-xs));
    color: var(--gray-500);
    line-height: 1.3;
    max-width: 14ch;
  }

  .stat-divider {
    display: none;
  }

  @media (min-width: 768px) {
    .stat-item {
      padding: var(--space-8) var(--space-6);
      gap: var(--space-2);
    }

    .stat-text strong,
    .stat-text span {
      font-size: var(--text-xs);
    }
  }

  /* ══════════════════════════════════════════
     PASOS — padding moderado
  ══════════════════════════════════════════ */
  .section--elevated {
    padding-block: clamp(2.5rem, 2rem + 2.5vw, 5rem);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-top: var(--space-8) !important;
  }

  .step-card {
    background: var(--surface-light);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-light);
    position: relative;
    overflow: hidden;
    text-align: left;
    transition:
      transform 0.4s var(--ease-out-expo),
      box-shadow 0.4s var(--ease-out-expo),
      border-color 0.4s var(--ease-out-expo);
  }

  .step-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 12px 24px rgba(0, 0, 0, 0.06),
      0 4px 8px rgba(0, 0, 0, 0.04);
    border-color: var(--gray-300);
  }

  .step-number {
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: var(--weight-black);
    color: var(--gray-100);
    line-height: 0.8;
    position: absolute;
    top: -6px;
    right: -4px;
    z-index: 0;
  }

  .step-card h3 {
    position: relative;
    z-index: 1;
    font-size: var(--text-base);
    color: var(--text-dark);
    margin-bottom: var(--space-2);
  }

  .step-card p {
    position: relative;
    z-index: 1;
    font-size: var(--text-sm);
    color: var(--text-dark-secondary);
    margin-bottom: 0;
    line-height: var(--leading-relaxed);
  }

  @media (min-width: 640px) {
    .steps-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-5);
    }

    .step-number {
      font-size: 5rem;
    }

    .step-card h3 {
      font-size: var(--text-lg);
      margin-bottom: var(--space-3);
    }
  }

  @media (min-width: 1024px) {
    .steps-grid {
      gap: var(--space-6);
    }

    .step-card {
      padding: var(--space-8);
    }

    .step-number {
      font-size: 6rem;
      top: -10px;
      right: -8px;
    }

    .step-card h3 {
      font-size: var(--text-xl);
      margin-bottom: var(--space-4);
    }
  }
</style>
