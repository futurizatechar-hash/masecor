---
/**
 * Detalle de Producto — Masecor Web
 *
 * Layout editorial: imagen izquierda, info derecha.
 * Specs con tabla minimalista. Schema.org Product.
 */
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {
  getWhatsAppUrl,
  WHATSAPP_CONFIG,
  SITE_CONFIG,
} from '../../utils/constants';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.data.slug ?? product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { data } = product;

const whatsappUrl = getWhatsAppUrl(WHATSAPP_CONFIG.productMessage(data.name));

const lineLabels: Record<string, string> = {
  premium: 'Premium',
  prisma: 'Prisma',
  standard: 'Standard',
  lavadero: 'Lavadero',
  accesorios: 'Accesorios',
};

const categoryLabels: Record<string, string> = {
  'bacha-simple': 'Bacha Simple',
  'bacha-doble': 'Bacha Doble',
  'mesada-ciega': 'Mesada Ciega',
  'mesada-integrada': 'Mesada Integrada',
  'pileta-lavadero': 'Pileta de Lavadero',
  accesorio: 'Accesorio',
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: data.name,
  description: data.description,
  brand: { '@type': 'Brand', name: SITE_CONFIG.name },
  material: data.material,
  category: categoryLabels[data.category] ?? data.category,
  manufacturer: {
    '@type': 'Organization',
    name: SITE_CONFIG.name,
    url: SITE_CONFIG.url,
  },
  offers: {
    '@type': 'Offer',
    availability: data.available
      ? 'https://schema.org/InStock'
      : 'https://schema.org/OutOfStock',
    priceCurrency: 'ARS',
    seller: { '@type': 'Organization', name: SITE_CONFIG.name },
  },
};
---

<Layout
  title={data.name}
  description={data.description}
  productName={data.name}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(productSchema)}
  />

  <main>
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Navegación">
      <div class="container">
        <ol class="breadcrumb__list">
          <li><a href="/" class="breadcrumb__link">Inicio</a></li>
          <li><a href="/productos" class="breadcrumb__link">Productos</a></li>
          <li class="breadcrumb__current" aria-current="page">{data.name}</li>
        </ol>
      </div>
    </nav>

    <!-- Product -->
    <section class="product" aria-label={`Detalles de ${data.name}`}>
      <div class="container product__grid">
        <!-- Image -->
        <div class="product__image" data-reveal="scale">
          <div class="product__image-inner">
            {
              data.image ? (
                <img
                  src={data.image}
                  alt={`Bacha de acero inoxidable ${data.name}`}
                  class="product__image-img"
                  loading="eager"
                  decoding="async"
                />
              ) : (
                <svg
                  width="64"
                  height="64"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="0.5"
                  aria-hidden="true"
                >
                  <rect x="3" y="3" width="18" height="18" rx="2" />
                  <circle cx="8.5" cy="8.5" r="1.5" />
                  <path d="m21 15-5-5L5 21" />
                </svg>
              )
            }
          </div>
        </div>

        <!-- Info -->
        <div class="product__info">
          <div data-reveal>
            <span class="eyebrow"
              >{lineLabels[data.line] ?? data.line} · {
                categoryLabels[data.category] ?? data.category
              }</span
            >
            <h1 class="product__name steel-shimmer">{data.name}</h1>
            <p class="product__material">{data.material}</p>
          </div>

          <p class="product__description" data-reveal data-delay="1">
            {data.description}
          </p>

          <!-- Specs -->
          <div class="product__specs" data-reveal data-delay="2">
            <h2 class="product__section-title">Especificaciones</h2>
            <dl class="product__specs-list">
              {
                data.dimensions?.width && (
                  <div class="product__spec-row">
                    <dt>Ancho</dt>
                    <dd>
                      {data.dimensions.width} {data.dimensions.unit}
                    </dd>
                  </div>
                )
              }
              {
                data.dimensions?.depth && (
                  <div class="product__spec-row">
                    <dt>Profundidad</dt>
                    <dd>
                      {data.dimensions.depth} {data.dimensions.unit}
                    </dd>
                  </div>
                )
              }
              {
                data.dimensions?.height && (
                  <div class="product__spec-row">
                    <dt>Alto</dt>
                    <dd>
                      {data.dimensions.height} {data.dimensions.unit}
                    </dd>
                  </div>
                )
              }
              {
                data.thickness && (
                  <div class="product__spec-row">
                    <dt>Espesor</dt>
                    <dd>{data.thickness}</dd>
                  </div>
                )
              }
              {
                data.installationType && (
                  <div class="product__spec-row">
                    <dt>Instalación</dt>
                    <dd class="capitalize">{data.installationType}</dd>
                  </div>
                )
              }
            </dl>
          </div>

          <!-- Features -->
          {
            data.features.length > 0 && (
              <div class="product__features" data-reveal data-delay="3">
                <h2 class="product__section-title">Características</h2>
                <ul class="product__features-list">
                  {data.features.map((feature: string) => (
                    <li class="product__feature">
                      <span class="product__feature-dash">—</span>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
        </div>
      </div>
    </section>

    <!-- Blueprint -->
    <section
      class="blueprint section section--elevated"
      aria-label="Plano Técnico"
    >
      <div class="container">
        <div class="blueprint__header" data-reveal>
          <span class="eyebrow">Dimensiones</span>
          <h2>Plano Técnico</h2>
          <p class="blueprint__text">
            Esquema referencial de medidas e instalación. Las dimensiones
            exactas pueden variar según el modelo.
          </p>
        </div>
        <div
          class="blueprint__image-wrapper"
          data-reveal="fade-up"
          data-delay="1"
        >
          <img
            src="/images/blueprint-placeholder.webp"
            alt="Plano técnico referencial"
            class="blueprint__img"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <div class="final-cta-wrapper" aria-label="Acciones">
      <div class="container">
        <div class="product__cta product__cta--centered" data-reveal>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--whatsapp"
            data-event="whatsapp_click"
            data-product={data.name}
            id="product-whatsapp-cta"
          >
            Consultar por este producto
          </a>
          <a
            href="/productos"
            class="btn btn--ghost"
            style="display: flex; align-items: center; justify-content: center; height: 100%;"
          >
            ← Volver al catálogo
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const cta = document.getElementById('product-whatsapp-cta');
  cta?.addEventListener('click', () => {
    const product = cta.getAttribute('data-product') ?? 'unknown';
    if (typeof window.gtag === 'function') {
      window.gtag('event', 'whatsapp_click', {
        event_category: 'conversion',
        event_label: product,
        value: 1,
      });
    }
  });
</script>

<style>
  /* ── Breadcrumb ── */
  .breadcrumb {
    padding: 8rem 0 var(--space-4);
    background-color: var(--surface-light);
  }

  .breadcrumb__list {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--gray-500);
  }

  .breadcrumb__list li:not(:last-child)::after {
    content: '/';
    margin-left: var(--space-2);
    color: var(--gray-400);
  }

  .breadcrumb__link {
    color: var(--gray-500);
    text-decoration: none;
  }

  .breadcrumb__link:hover {
    color: var(--black);
    opacity: 1;
  }

  .breadcrumb__current {
    color: var(--text-dark);
  }

  /* ── Product ── */
  .product {
    padding: var(--space-8) 0 var(--section-py);
    background-color: var(--surface-light);
  }

  .product__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  /* Image */
  .product__image-inner {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gray-100);
    color: var(--gray-400);
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .product__image-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out-expo);
  }

  .product__image:hover .product__image-img {
    transform: scale(1.05);
  }

  /* Info */
  .product__name {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--weight-extrabold);
    color: var(--text-dark);
    letter-spacing: var(--tracking-tighter);
    margin-bottom: var(--space-2);
  }

  .product__material {
    font-size: var(--text-xs);
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    margin-bottom: var(--space-6);
  }

  .product__description {
    font-size: var(--text-md);
    color: var(--text-dark-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-10);
    max-width: 500px;
  }

  /* Specs */
  .product__specs {
    margin-bottom: var(--space-8);
  }

  .product__section-title {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--gray-500);
    margin-bottom: var(--space-4);
  }

  .product__specs-list {
    display: flex;
    flex-direction: column;
  }

  .product__spec-row {
    display: flex;
    justify-content: space-between;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--gray-200);
  }

  .product__spec-row dt {
    font-size: var(--text-sm);
    color: var(--gray-500);
  }

  .product__spec-row dd {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-dark);
  }

  .capitalize {
    text-transform: capitalize;
  }

  /* Features */
  .product__features {
    margin-bottom: var(--space-10);
  }

  .product__features-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .product__feature {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-dark-secondary);
  }

  .product__feature-dash {
    color: var(--gray-400);
    flex-shrink: 0;
  }

  /* CTA */
  .product__cta {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Responsive */
  @media (min-width: 1024px) {
    .product__grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
      gap: var(--space-16);
    }

    .product__cta {
      flex-direction: row;
      align-items: center;
    }
  }

  .product__cta--centered {
    justify-content: center;
    align-items: center;
    border-top: none;
    margin-top: 0;
    padding-top: 0;
    gap: var(--space-6);
  }

  .final-cta-wrapper {
    background: var(--surface-light);
    padding-top: var(--space-16);
    padding-bottom: var(--space-24);
    display: flex;
    justify-content: center;
    border-top: 1px solid var(--gray-200);
  }

  /* Blueprint */
  .blueprint {
    text-align: center;
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
    background: var(--surface-white);
  }

  .blueprint__header {
    margin-bottom: var(--space-8);
  }

  .blueprint__text {
    font-size: var(--text-md);
    color: var(--text-dark-secondary);
    max-width: 600px;
    margin-inline: auto;
  }

  .blueprint__image-wrapper {
    max-width: 800px;
    margin-inline: auto;
    background: var(--surface-light);
    padding: var(--space-8);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
  }

  .blueprint__img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
