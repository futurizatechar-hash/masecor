---
/**
 * Detalle de Producto — Masecor Web
 *
 * Layout editorial: imagen izquierda, info derecha.
 * Specs con tabla minimalista. Schema.org Product.
 */
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BackToCatalog from '../../components/BackToCatalog.astro';
import {
  getWhatsAppUrl,
  WHATSAPP_CONFIG,
  SITE_CONFIG,
} from '../../utils/constants';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.data.slug ?? product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { data } = product;

const whatsappUrl = getWhatsAppUrl(WHATSAPP_CONFIG.productMessage(data.name));

const lineLabels: Record<string, string> = {
  premium: 'Premium',
  prisma: 'Prisma',
  standard: 'Estándar',
  lavadero: 'Lavadero',
  accesorios: 'Accesorios',
};

const categoryLabels: Record<string, string> = {
  'bacha-simple': 'Bacha Simple',
  'bacha-doble': 'Bacha Doble',
  'mesada-ciega': 'Mesada Ciega',
  'mesada-integrada': 'Mesada Integrada',
  'pileta-lavadero': 'Pileta de Lavadero',
  accesorio: 'Accesorio',
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: data.name,
  description: data.description,
  brand: { '@type': 'Brand', name: SITE_CONFIG.name },
  material: data.material,
  category: categoryLabels[data.category] ?? data.category,
  manufacturer: {
    '@type': 'Organization',
    name: SITE_CONFIG.name,
    url: SITE_CONFIG.url,
  },
  offers: {
    '@type': 'Offer',
    availability: data.available
      ? 'https://schema.org/InStock'
      : 'https://schema.org/OutOfStock',
    priceCurrency: 'ARS',
    seller: { '@type': 'Organization', name: SITE_CONFIG.name },
  },
};
---

<Layout
  title={data.name}
  description={data.description}
  productName={data.name}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(productSchema)}
  />

  <main>
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Navegación">
      <div class="container">
        <ol class="breadcrumb__list">
          <li><a href="/" class="breadcrumb__link">Inicio</a></li>
          <li><a href="/productos" class="breadcrumb__link">Productos</a></li>
          <li class="breadcrumb__current" aria-current="page">{data.name}</li>
        </ol>
      </div>
    </nav>

    <!-- Product -->
    <section class="product" aria-label={`Detalles de ${data.name}`}>
      <div class="container product__grid">
        <!-- Gallery + Image -->
        <div class="product__gallery-wrapper" data-reveal="scale">
          <!-- Thumbnails column -->
          {data.image && (
            <div class="product__thumbs">
              <button 
                class="product__thumb-btn is-active" 
                data-img-src={data.image}
                aria-label="Ver imagen 1"
              >
                <img src={data.image} alt="" class="product__thumb-img" />
              </button>
              {data.gallery && data.gallery.map((imgUrl: string, idx: number) => (
                <button 
                  class="product__thumb-btn" 
                  data-img-src={imgUrl}
                  aria-label={`Ver imagen ${idx + 2}`}
                >
                  <img src={imgUrl} alt="" class="product__thumb-img" />
                </button>
              ))}
            </div>
          )}

          <!-- Active Main Image -->
          <div class="product__image-main">
            {
              data.image ? (
                <img
                  src={data.image}
                  alt={`Bacha de acero inoxidable ${data.name}`}
                  class="product__image-img"
                  id="main-product-img"
                  loading="eager"
                  decoding="async"
                />
              ) : (
                <div class="product__image-placeholder">
                  <svg
                    width="64"
                    height="64"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="0.5"
                    aria-hidden="true"
                  >
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <circle cx="8.5" cy="8.5" r="1.5" />
                    <path d="m21 15-5-5L5 21" />
                  </svg>
                </div>
              )
            }
          </div>
        </div>

        <!-- Info -->
        <div 
          class="product__info"
          id="product-details-root"
          data-variants={JSON.stringify(data.variants || [])}
          data-options={JSON.stringify(data.options || [])}
          data-product-name={data.name}
        >
          <div data-reveal>
            <span class="eyebrow"
              >{lineLabels[data.line] ?? data.line} · {
                categoryLabels[data.category] ?? data.category
              }</span
            >
            <h1 class="product__name">{data.name}</h1>
            <p class="product__material">{data.material}</p>
          </div>

          <!-- Options / Variants selectors -->
          {
            data.options && data.options.length > 0 && (
              <div class="product__options" data-reveal data-delay="1">
                {data.options.map((opt: any, optIdx: number) => (
                  <div class="product__option-group" data-option-name={opt.name}>
                    <span class="product__option-label">{opt.name}</span>
                    <div class="product__option-values">
                      {opt.values.map((val: string, valIdx: number) => (
                        <button
                          type="button"
                          class:list={[
                            "product__option-btn",
                            { "is-active": valIdx === 0 }
                          ]}
                          data-option-name={opt.name}
                          data-option-value={val}
                        >
                          {val}
                        </button>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            )
          }

          <!-- Actions (WhatsApp) -->
          <div class="product__actions" data-reveal data-delay="2">
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--whatsapp btn--lg product__buy-btn"
              data-event="whatsapp_click"
              data-product={data.name}
              id="product-whatsapp-cta"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
              </svg>
              Consultar por WhatsApp
            </a>
          </div>

        </div>
      </div>

      <!-- Extended Info -->
      <div class="container product__extended-info">
        <div class="product__details-grid">
          <!-- Description & Features (Left Column) -->
          <div class="product__details-left">
            {data.description && (
              <div class="product__details-block" data-reveal>
                <h2 class="product__section-title">Descripción</h2>
                <p class="product__description-text">
                  {data.description}
                </p>
              </div>
            )}

            {data.features && data.features.length > 0 && (
              <div class="product__details-block" data-reveal data-delay="1">
                <h2 class="product__section-title">Características</h2>
                <ul class="product__features-list">
                  {data.features.map((feature: string) => (
                    <li class="product__feature">
                      <span class="product__feature-dash">—</span>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>

          <!-- Specifications (Right Column) -->
          <div class="product__details-right">
            <div class="product__details-block" data-reveal data-delay="2">
              <h2 class="product__section-title">Especificaciones</h2>
              <dl class="product__specs-list">
                {
                  data.dimensions?.width && (
                    <div class="product__spec-row">
                      <dt>Ancho</dt>
                      <dd>
                        {data.dimensions.width} {data.dimensions.unit}
                      </dd>
                    </div>
                  )
                }
                {
                  data.dimensions?.depth && (
                    <div class="product__spec-row">
                      <dt>Profundidad</dt>
                      <dd>
                        {data.dimensions.depth} {data.dimensions.unit}
                      </dd>
                    </div>
                  )
                }
                {
                  data.dimensions?.height && (
                    <div class="product__spec-row">
                      <dt>Alto</dt>
                      <dd>
                        {data.dimensions.height} {data.dimensions.unit}
                      </dd>
                    </div>
                  )
                }
                {
                  data.thickness && (
                    <div class="product__spec-row">
                      <dt>Espesor</dt>
                      <dd>{data.thickness}</dd>
                    </div>
                  )
                }
                {
                  data.installationType && (
                    <div class="product__spec-row">
                      <dt>Instalación</dt>
                      <dd class="capitalize">{data.installationType}</dd>
                    </div>
                  )
                }
              </dl>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Blueprint -->
    {data.blueprint && (
      <section
        class="blueprint section section--elevated"
        aria-label="Plano Técnico"
      >
        <div class="container">
          <div class="blueprint__header" data-reveal>
            <span class="eyebrow">Dimensiones</span>
            <h2>Plano Técnico</h2>
            <p class="blueprint__text">
              Esquema referencial de medidas e instalación. Las dimensiones
              exactas pueden variar según el modelo.
            </p>
          </div>
          <div
            class="blueprint__image-wrapper"
            data-reveal="fade-up"
            data-delay="1"
          >
            <img
              src={data.blueprint}
              alt={`Plano técnico de ${data.name}`}
              class="blueprint__img"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </section>
    )}

    <!-- Lightbox Modal -->
    <div id="product-lightbox" class="lightbox" aria-hidden="true" role="dialog" aria-label="Galería a pantalla completa">
      <button class="lightbox__close" aria-label="Cerrar galería">&times;</button>
      
      <button class="lightbox__arrow lightbox__arrow--prev" aria-label="Imagen anterior">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="lightbox__content">
        <img id="lightbox-img" src="" alt="Vista ampliada del producto" class="lightbox__img" />
        <span class="lightbox__caption" id="lightbox-caption"></span>
      </div>

      <button class="lightbox__arrow lightbox__arrow--next" aria-label="Imagen siguiente">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>

    <!-- Back Link (Always at the very end) -->
    <BackToCatalog />

  </main>
</Layout>

<script>
  const cta = document.getElementById('product-whatsapp-cta');
  cta?.addEventListener('click', () => {
    const product = cta.getAttribute('data-product') ?? 'unknown';
    if (typeof window.gtag === 'function') {
      window.gtag('event', 'whatsapp_click', {
        event_category: 'conversion',
        event_label: product,
        value: 1,
      });
    }
  });

  // Thumbnail hover/click swapping Setup & Lightbox Gallery
  function setupGallery() {
    const thumbs = document.querySelectorAll('.product__thumb-btn');
    const mainImg = document.getElementById('main-product-img') as HTMLImageElement;
    const lightbox = document.getElementById('product-lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxClose = document.querySelector('.lightbox__close');
    const lightboxPrev = document.querySelector('.lightbox__arrow--prev');
    const lightboxNext = document.querySelector('.lightbox__arrow--next');
    const lightboxCaption = document.getElementById('lightbox-caption');

    if (!mainImg || !lightbox || !lightboxImg) return;

    let images: string[] = [];
    
    function updateImagesList() {
      images = [];
      thumbs.forEach((thumb) => {
        const src = thumb.getAttribute('data-img-src');
        if (src && !images.includes(src)) {
          images.push(src);
        }
      });
      if (images.length === 0 && mainImg.src) {
        images.push(mainImg.getAttribute('src') || mainImg.src);
      }
    }

    updateImagesList();
    let currentIdx = 0;

    function swapImage(thumb: Element) {
      const newSrc = thumb.getAttribute('data-img-src');
      if (newSrc) {
        mainImg.src = newSrc;
      }
      thumbs.forEach((t) => t.classList.remove('is-active'));
      thumb.classList.add('is-active');
    }

    thumbs.forEach((thumb) => {
      thumb.addEventListener('mouseenter', () => swapImage(thumb));
      thumb.addEventListener('click', (e) => {
        e.preventDefault();
        swapImage(thumb);
      });
    });

    // Lightbox Controls
    function openLightbox() {
      updateImagesList();
      const currentSrc = mainImg.getAttribute('src') || mainImg.src;
      const mainPath = new URL(mainImg.src, window.location.href).pathname;
      currentIdx = images.findIndex(img => {
        const imgPath = new URL(img, window.location.href).pathname;
        return imgPath === mainPath;
      });
      if (currentIdx === -1) currentIdx = 0;

      updateLightbox();
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    function updateLightbox() {
      const src = images[currentIdx];
      if (src) {
        lightboxImg.src = src;
      }
      if (lightboxCaption) {
        lightboxCaption.textContent = `${currentIdx + 1} / ${images.length}`;
      }
      if (images.length <= 1) {
        lightbox.classList.add('single-image');
      } else {
        lightbox.classList.remove('single-image');
      }
    }

    function navigateLightbox(dir: number) {
      currentIdx = (currentIdx + dir + images.length) % images.length;
      updateLightbox();
    }

    mainImg.style.cursor = 'zoom-in';
    mainImg.addEventListener('click', () => {
      openLightbox();
    });

    lightboxClose?.addEventListener('click', (e) => {
      e.stopPropagation();
      closeLightbox();
    });

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) {
        closeLightbox();
      }
    });

    lightboxPrev?.addEventListener('click', (e) => {
      e.stopPropagation();
      navigateLightbox(-1);
    });

    lightboxNext?.addEventListener('click', (e) => {
      e.stopPropagation();
      navigateLightbox(1);
    });

    function handleKeyDown(e: KeyboardEvent) {
      if (!lightbox.classList.contains('is-open')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigateLightbox(-1);
      if (e.key === 'ArrowRight') navigateLightbox(1);
    }

    document.removeEventListener('keydown', handleKeyDown);
    document.addEventListener('keydown', handleKeyDown);
  }

  // Variant Selection Logic
  function setupVariants() {
    const root = document.getElementById('product-details-root');
    if (!root) return;

    const variants = JSON.parse(root.getAttribute('data-variants') || '[]');
    const options = JSON.parse(root.getAttribute('data-options') || '[]');
    const productName = root.getAttribute('data-product-name') || '';
    const mainImg = document.getElementById('main-product-img') as HTMLImageElement;
    const wCta = document.getElementById('product-whatsapp-cta') as HTMLAnchorElement;

    if (variants.length === 0 || options.length === 0) return;

    const currentSelections: Record<string, string> = {};

    // Initialize with active buttons
    const activeBtns = root.querySelectorAll('.product__option-btn.is-active');
    activeBtns.forEach((btn) => {
      const optName = btn.getAttribute('data-option-name');
      const optVal = btn.getAttribute('data-option-value');
      if (optName && optVal) {
        currentSelections[optName] = optVal;
      }
    });

    function updateSelection() {
      // Find matching variant
      const matchingVariant = variants.find((v: any) => {
        return Object.keys(currentSelections).every(
          (key) => v.options[key] === currentSelections[key]
        );
      });

      // Update image if variant has a specific image
      if (matchingVariant && matchingVariant.image && mainImg) {
        mainImg.src = matchingVariant.image;
        // Also update thumbnail active states
        const thumbs = document.querySelectorAll('.product__thumb-btn');
        thumbs.forEach((thumb) => {
          const imgUrl = thumb.getAttribute('data-img-src');
          if (imgUrl === matchingVariant.image) {
            thumb.classList.add('is-active');
          } else {
            thumb.classList.remove('is-active');
          }
        });
      }

      // Update WhatsApp URL
      if (wCta) {
        const optionDetails = Object.entries(currentSelections)
          .map(([key, val]) => `${key}: ${val}`)
          .join(', ');
        const message = `Hola Masecor, estoy interesado/a en *${productName}* (${optionDetails}) que vi en su sitio web. ¿Podrían darme más información sobre disponibilidad y precios?`;
        wCta.href = `https://wa.me/5493516659066?text=${encodeURIComponent(message)}`;
      }

      // Update availability visual indicators of other buttons
      options.forEach((opt: any) => {
        const btns = root.querySelectorAll(`.product__option-btn[data-option-name="${opt.name}"]`);
        btns.forEach((btn) => {
          const val = btn.getAttribute('data-option-value');
          if (!val) return;

          // Test if this value is available with current other selections
          const tempSelections = { ...currentSelections, [opt.name]: val };
          const isPossible = variants.some((v: any) => {
            return Object.keys(tempSelections).every(
              (key) => v.options[key] === tempSelections[key] && v.available
            );
          });

          if (isPossible) {
            btn.classList.remove('is-disabled');
          } else {
            btn.classList.add('is-disabled');
          }
        });
      });
    }

    // Set up button listeners
    const btns = root.querySelectorAll('.product__option-btn');
    btns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const optName = btn.getAttribute('data-option-name');
        const optVal = btn.getAttribute('data-option-value');
        if (!optName || !optVal) return;

        // Update active class
        const siblingBtns = root.querySelectorAll(`.product__option-btn[data-option-name="${optName}"]`);
        siblingBtns.forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');

        // Update selections and UI
        currentSelections[optName] = optVal;
        updateSelection();
      });
    });

    // Run initial update
    updateSelection();
  }

  setupGallery();
  setupVariants();
  document.addEventListener('astro:page-load', () => {
    setupGallery();
    setupVariants();
  });
</script>

<style>
  /* ── Breadcrumb ── */
  .breadcrumb {
    padding: clamp(6rem, 5.5rem + 2vw, 8rem) 0 var(--space-4);
    background-color: var(--surface-light);
  }

  .breadcrumb__list {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--gray-500);
  }

  .breadcrumb__list li:not(:last-child)::after {
    content: '/';
    margin-left: var(--space-2);
    color: var(--gray-400);
  }

  .breadcrumb__link {
    color: var(--gray-500);
    text-decoration: none;
  }

  .breadcrumb__link:hover {
    color: var(--black);
    opacity: 1;
  }

  .breadcrumb__current {
    color: var(--text-dark);
  }

  /* ── Product ── */
  .product {
    padding: var(--space-8) 0 var(--space-12);
    background-color: var(--surface-light);
  }

  .product__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  /* Gallery Layout */
  .product__gallery-wrapper {
    display: flex;
    flex-direction: column-reverse;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .product__gallery-wrapper {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-4);
    }
  }

  .product__thumbs {
    display: flex;
    flex-direction: row;
    gap: var(--space-2.5);
    overflow-x: auto;
    padding-bottom: var(--space-1);
    -webkit-overflow-scrolling: touch;
  }

  @media (min-width: 768px) {
    .product__thumbs {
      flex-direction: column;
      overflow-x: visible;
      padding-bottom: 0;
      flex-shrink: 0;
      width: 76px;
    }
  }

  .product__thumb-btn {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-sm);
    padding: var(--space-2); /* Extra padding to prevent thumbnail images from touching borders */
    cursor: pointer;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: all var(--transition-fast);
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .product__thumb-btn {
      width: 76px;
      height: 76px;
    }
  }

  .product__thumb-btn:hover,
  .product__thumb-btn.is-active {
    border-color: var(--black-rich);
    box-shadow: var(--shadow-sm);
  }

  .product__thumb-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain !important;
  }

  .product__image-main {
    width: 100%;
    min-height: 280px;
    max-height: 500px;
    background: var(--white);
    border-radius: var(--radius-md);
    border: 1px solid var(--gray-200);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
  }

  @media (min-width: 768px) {
    .product__image-main {
      width: calc(100% - 92px); /* 76px thumbs + 16px (space-4) gap */
    }
  }

  @media (min-width: 1024px) {
    .product__image-main {
      min-height: 350px;
      max-height: 550px;
    }
  }

  .product__image-placeholder {
    width: 100%;
    height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gray-400);
  }

  .product__image-img {
    display: block;
    max-width: 85%;
    max-height: 420px;
    width: auto;
    height: auto;
    object-fit: contain;
    transition: transform 0.6s var(--ease-out-expo);
  }

  @media (min-width: 1024px) {
    .product__image-img {
      max-height: 480px;
    }
  }

  .product__image-main:hover .product__image-img {
    transform: scale(1.03);
  }

  /* Info */
  .product__name {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.35rem + 0.75vw, 1.75rem);
    font-weight: var(--weight-extrabold);
    color: var(--text-dark);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-3);
    line-height: 1.25;
  }

  .product__material {
    font-size: var(--text-xs);
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
