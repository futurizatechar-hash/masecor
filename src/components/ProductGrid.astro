---
/**
 * ProductGrid — Masecor Web
 *
 * Grilla de productos con barra de filtros colapsable estilo Mercado Libre.
 */

interface Product {
  id: string;
  name: string;
  slug?: string;
  line: string;
  category: string;
  shortDescription: string;
  image: string;
  material?: string;
  featured?: boolean;
  thickness?: string;
  installationType?: string;
  dimensions?: {
    width?: number;
    depth?: number;
    height?: number;
    unit?: string;
  };
}

interface Props {
  products: Product[];
  showFilters?: boolean;
}

import ProductCard from './ProductCard.astro';

const { products, showFilters = false } = Astro.props;

// Helper function to tag widths into sensible ranges
function getWidthRangeTag(width: number | undefined): string | null {
  if (width === undefined || isNaN(width)) return null;
  if (width < 600) return 'under-60';
  if (width >= 600 && width < 800) return '60-79';
  if (width >= 800 && width < 1200) return '80-119';
  if (width >= 1200 && width < 1600) return '120-159';
  if (width >= 1600) return 'over-160';
  return null;
}

// Hierarchical classification helper
function getProductCategories(product: Product) {
  const name = product.name.toLowerCase();
  const cat = product.category;
  
  let mainCategory = '';
  let subCategory = '';
  
  if (cat === 'bacha-simple') {
    mainCategory = 'bachas';
    subCategory = 'simple';
  } else if (cat === 'bacha-doble') {
    mainCategory = 'bachas';
    subCategory = 'doble';
  } else if (cat === 'mesada-ciega') {
    mainCategory = 'mesadas';
    subCategory = 'ciega';
  } else if (cat === 'mesada-integrada') {
    mainCategory = 'mesadas';
    subCategory = 'integrada';
  } else if (cat === 'pileta-lavadero') {
    mainCategory = 'lavadero';
    subCategory = 'pileta';
  } else if (cat === 'accesorio') {
    mainCategory = 'accesorios';
    if (name.includes('canasto')) subCategory = 'canastos';
    else if (name.includes('colador')) subCategory = 'coladores';
    else if (name.includes('griferia')) subCategory = 'griferia';
    else if (name.includes('dispenser') || name.includes('dosificador')) subCategory = 'dispenser';
    else if (name.includes('sifon')) subCategory = 'sifones';
    else if (name.includes('sopapa') || name.includes('sop-')) subCategory = 'sopapas';
    else if (name.includes('roller')) subCategory = 'roller';
    else if (name.includes('asadera')) subCategory = 'asadera';
    else subCategory = 'otros';
  } else {
    mainCategory = 'otros';
    subCategory = 'otros';
  }
  
  return { mainCategory, subCategory };
}

// Extract unique filterable dimensions dynamically
const lines = [...new Set(products.map((p) => p.line))].filter(Boolean);
const thicknesses = [...new Set(products.map((p) => p.thickness))]
  .filter(Boolean)
  .sort();
const installations = [
  ...new Set(products.map((p) => p.installationType)),
].filter(Boolean);

const widthRanges = ['under-60', '60-79', '80-119', '120-159', 'over-160'];

const lineLabels: Record<string, string> = {
  premium: 'Premium',
  prisma: 'Prisma',
  standard: 'Estándar',
  lavadero: 'Lavadero',
  accesorios: 'Accesorios',
};

const mainCategoryLabels: Record<string, string> = {
  bachas: 'Bachas',
  mesadas: 'Mesadas',
  accesorios: 'Accesorios',
  lavadero: 'Lavaderos',
};

const subCategoryLabels: Record<string, string> = {
  simple: 'Simple',
  doble: 'Doble',
  ciega: 'Ciega',
  integrada: 'Integrada',
  pileta: 'Pileta',
  canastos: 'Canastos',
  coladores: 'Coladores',
  griferia: 'Grifería',
  dispenser: 'Dosificadores',
  sifones: 'Sifones',
  sopapas: 'Sopapas',
  roller: 'Roller / Escurridor',
  asadera: 'Asadera',
  otros: 'Otros Accesorios',
};

const installationLabels: Record<string, string> = {
  'sobre-mueble': 'Sobre Mueble',
  'bajo-mesada': 'Bajo Mesada',
  empotrar: 'Empotrar',
  colgar: 'Colgar',
  'sobre-mesada-bajo-mesada': 'Sobre/Bajo Mesada',
};

const widthRangeLabels: Record<string, string> = {
  'under-60': 'Menos de 60 cm',
  '60-79': '60 a 79 cm',
  '80-119': '80 a 119 cm',
  '120-159': '120 a 159 cm',
  'over-160': '160 cm o más',
};

// Compute counts statically for catalog overview
const lineCounts: Record<string, number> = {};
const mainCategoryCounts: Record<string, number> = {};
const categoryCounts: Record<string, number> = {};
const thicknessCounts: Record<string, number> = {};
const installationCounts: Record<string, number> = {};
const widthRangeCounts: Record<string, number> = {};

// Build groupedCategories
const groupedCategories: Record<string, string[]> = {};
products.forEach((p) => {
  const { mainCategory, subCategory } = getProductCategories(p);
  if (mainCategory && subCategory) {
    if (!groupedCategories[mainCategory]) {
      groupedCategories[mainCategory] = [];
    }
    if (!groupedCategories[mainCategory].includes(subCategory)) {
      groupedCategories[mainCategory].push(subCategory);
    }
  }
});

products.forEach((p) => {
  if (p.line) lineCounts[p.line] = (lineCounts[p.line] || 0) + 1;
  if (p.thickness) thicknessCounts[p.thickness] = (thicknessCounts[p.thickness] || 0) + 1;
  if (p.installationType) installationCounts[p.installationType] = (installationCounts[p.installationType] || 0) + 1;
  
  const { mainCategory, subCategory } = getProductCategories(p);
  if (mainCategory) {
    mainCategoryCounts[mainCategory] = (mainCategoryCounts[mainCategory] || 0) + 1;
  }
  if (subCategory) {
    categoryCounts[subCategory] = (categoryCounts[subCategory] || 0) + 1;
  }
  
  const wRange = getWidthRangeTag(p.dimensions?.width);
  if (wRange) {
    widthRangeCounts[wRange] = (widthRangeCounts[wRange] || 0) + 1;
  }
});

const activeWidthRanges = widthRanges.filter((range) => (widthRangeCounts[range] || 0) > 0);
---

<section class="catalog" aria-label="Catálogo de productos">
  <div class="catalog__layout">
    {
      showFilters && (
        <div class="catalog__filters-wrapper">
          <div class="mobile-filters-header">
            <button
              class="mobile-filters-toggle"
              id="mobile-filters-btn"
              aria-expanded="false"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
              </svg>
              Filtrar Catálogo
            </button>
          </div>
          <aside class="catalog__sidebar" id="catalog-sidebar">
            <div class="sidebar__drawer-header">
              <h2 class="sidebar__drawer-title">Filtros</h2>
              <button
                class="sidebar__drawer-close"
                id="sidebar-close-btn"
                aria-label="Cerrar filtros"
              >
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <>
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                  </>
                </svg>
              </button>
            </div>

            <div class="sidebar__drawer-content">
              {/* Active Filters Container */}
              <div
                class="active-filters"
                id="active-filters-section"
                style="display: none;"
              >
                <div class="active-filters__header">
                  <span class="active-filters__title">Filtros aplicados</span>
                  <button class="active-filters__clear-all" id="clear-all-btn">
                    Limpiar todos
                  </button>
                </div>
                <div class="active-filters__chips" id="active-chips-container">
                  {/* Chips dynamically added by JS */}
                </div>
              </div>

              {/* Category: Line */}
              {lines.length > 0 && (
                <div class="filter-section" data-section-type="line">
                  <button
                    class="filter-section__header"
                    aria-expanded="true"
                    aria-controls="filter-body-line"
                  >
                    <span>Línea</span>
                    <svg
                      class="chevron"
                      width="12"
                      height="12"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="6 9 12 15 18 9" />
                    </svg>
                  </button>
                  <div class="filter-section__body" id="filter-body-line">
                    <ul class="filter-list">
                      {lines.map((line) => (
                        <li>
                          <label class="filter-checkbox-label">
                            <input
                              type="checkbox"
                              class="filter-checkbox"
                              data-filter-type="line"
                              value={line}
                            />
                            <span class="checkbox-custom"></span>
                            <span class="label-text">{lineLabels[line] ?? line}</span>
                            <span class="filter-count">({lineCounts[line] || 0})</span>
                          </label>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              )}

              {/* Category: Category / Type */}
              {Object.keys(groupedCategories).length > 0 && (
                <div class="filter-section" data-section-type="category">
                  <button
                    class="filter-section__header"
                    aria-expanded="true"
                    aria-controls="filter-body-category"
                  >
                    <span>Tipo de Producto</span>
                    <svg
                      class="chevron"
                      width="12"
                      height="12"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="6 9 12 15 18 9" />
                    </svg>
                  </button>
                  <div class="filter-section__body" id="filter-body-category">
                    {Object.keys(groupedCategories).map((mainCat) => (
                      <div class="filter-subgroup">
                        <label class="filter-checkbox-label filter-checkbox-label--main">
                          <input
                            type="checkbox"
                            class="filter-checkbox main-category-checkbox"
                            value={mainCat}
                          />
                          <span class="checkbox-custom"></span>
                          <span class="label-text">{mainCategoryLabels[mainCat]}</span>
                          <button class="filter-only-btn" data-main-category={mainCat}>Solo</button>
                          <span class="filter-count">({mainCategoryCounts[mainCat] || 0})</span>
                        </label>
                        <ul class="filter-list filter-list--sub">
                          {groupedCategories[mainCat].map((subCat) => (
                            <li>
                              <label class="filter-checkbox-label">
                                <input
                                  type="checkbox"
                                  class="filter-checkbox sub-category-checkbox"
                                  data-filter-type="category"
                                  data-parent-category={mainCat}
                                  value={subCat}
                                />
                                <span class="checkbox-custom"></span>
                                <span class="label-text">{subCategoryLabels[subCat]}</span>
                                <span class="filter-count">({categoryCounts[subCat] || 0})</span>
                              </label>
                            </li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Category: Thickness */}
              {thicknesses.length > 0 && (
                <div class="filter-section" data-section-type="thickness">
                  <button
                    class="filter-section__header"
                    aria-expanded="true"
                    aria-controls="filter-body-thickness"
                  >
                    <span>Espesor del Acero</span>
                    <svg
                      class="chevron"
                      width="12"
                      height="12"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="6 9 12 15 18 9" />
                    </svg>
                  </button>
                  <div class="filter-section__body" id="filter-body-thickness">
                    <ul class="filter-list">
                      {thicknesses.map((thickness) => (
                        <li>
                          <label class="filter-checkbox-label">
                            <input
                              type="checkbox"
                              class="filter-checkbox"
                              data-filter-type="thickness"
                              value={thickness}
                            />
                            <span class="checkbox-custom"></span>
                            <span class="label-text">{thickness}</span>
                            <span class="filter-count">({thicknessCounts[thickness] || 0})</span>
                          </label>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              )}

              {/* Category: Installation Type */}
              {installations.length > 0 && (
                <div
                  class="filter-section"
                  data-section-type="installationType"
                >
                  <button
                    class="filter-section__header"
                    aria-expanded="true"
                    aria-controls="filter-body-installation"
                  >
                    <span>Instalación</span>
                    <svg
                      class="chevron"
                      width="12"
                      height="12"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="6 9 12 15 18 9" />
                    </svg>
                  </button>
                  <div
                    class="filter-section__body"
                    id="filter-body-installation"
                  >
                    <ul class="filter-list">
                      {installations.map((inst) => (
                        <li>
                          <label class="filter-checkbox-label">
                            <input
                              type="checkbox"
                              class="filter-checkbox"
                              data-filter-type="installationType"
                              value={inst}
                            />
                            <span class="checkbox-custom"></span>
                            <span class="label-text">{installationLabels[inst] ?? inst}</span>
                            <span class="filter-count">({installationCounts[inst] || 0})</span>
                          </label>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              )}

              {/* Category: Width Range */}
              {activeWidthRanges.length > 0 && (
                <div class="filter-section" data-section-type="widthRange">
                  <button
                    class="filter-section__header"
                    aria-expanded="true"
                    aria-controls="filter-body-widthRange"
                  >
                    <span>Ancho</span>
                    <svg
                      class="chevron"
                      width="12"
                      height="12"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="6 9 12 15 18 9" />
                    </svg>
                  </button>
                  <div class="filter-section__body" id="filter-body-widthRange">
                    <ul class="filter-list">
                      {activeWidthRanges.map((range) => (
                        <li>
                          <label class="filter-checkbox-label">
                            <input
                              type="checkbox"
                              class="filter-checkbox"
                              data-filter-type="widthRange"
                              value={range}
                            />
                            <span class="checkbox-custom"></span>
                            <span class="label-text">{widthRangeLabels[range] ?? range}</span>
                            <span class="filter-count">({widthRangeCounts[range] || 0})</span>
                          </label>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              )}
            </div>
          </aside>
          <div class="sidebar__backdrop" id="sidebar-backdrop" />
        </div>
      )
    }

    <div class="catalog__main">
      <div class="catalog__search-wrapper">
        <svg
          class="search-icon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
          type="search"
          id="catalog-search"
          placeholder="Buscar por nombre, línea o características..."
          aria-label="Buscar productos"
        />
      </div>

      <div class="catalog__grid" id="product-grid">
        {
          products.map((product) => (
            <div
              class="catalog__item"
              data-line={product.line}
              data-maincategory={getProductCategories(product).mainCategory || ''}
              data-subcategory={getProductCategories(product).subCategory || ''}
              data-thickness={product.thickness || ''}
              data-installation={product.installationType || ''}
              data-width-range={getWidthRangeTag(product.dimensions?.width) || ''}
              data-name={product.name.toLowerCase()}
              data-description={product.shortDescription.toLowerCase()}
            >
              <ProductCard
                name={product.name}
                slug={product.slug ?? product.id}
                line={product.line}
                description={product.shortDescription}
                image={product.image}
              />
            </div>
          ))
        }
      </div>

      {/* Dynamic Filter Empty State */}
      <div
        class="catalog__empty-filtered"
        id="catalog-empty-filtered"
        style="display: none;"
      >
        <svg
          width="40"
          height="40"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="12" cy="12" r="10"></circle><path d="m15 9-6 6"
          ></path><path d="m9 9 6 6"></path></svg
        >
        <p>No se encontraron productos con los filtros seleccionados.</p>
        <button
          class="btn btn--sm btn--outline"
          id="empty-reset-btn"
          style="margin-top: var(--space-2);"
        >
          Restablecer filtros
        </button>
      </div>

      {
        products.length === 0 && (
          <div class="catalog__empty">
            <p>No hay productos en esta sección.</p>
          </div>
        )
      }

      {/* Load More Button */}
      <div class="load-more-wrapper" id="load-more-wrapper" style="display: none;">
        <button class="load-more-btn" id="load-more-btn">
          <span id="load-more-label">Ver más productos</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </button>
        <p class="load-more-count" id="load-more-count"></p>
      </div>
    </div>
  </div>
</section>

<script>
  // Pagination config
  const PAGE_SIZE = 12;
  let visibleLimit = PAGE_SIZE;

  // Dynamic filter state
  const currentFilters: Record<string, string[]> = {
    line: [],
    category: [],
    thickness: [],
    installationType: [],
    widthRange: [],
  };

  // Human readable label mappings for active filter chips
  const lineLabels: Record<string, string> = {
    premium: 'Línea Premium',
    prisma: 'Línea Prisma',
    standard: 'Línea Estándar',
    lavadero: 'Línea Lavadero',
    accesorios: 'Accesorios',
  };

  const subCategoryLabels: Record<string, string> = {
    simple: 'Simple',
    doble: 'Doble',
    ciega: 'Ciega',
    integrada: 'Integrada',
    pileta: 'Pileta',
    canastos: 'Canastos',
    coladores: 'Coladores',
    griferia: 'Grifería',
    dispenser: 'Dosificadores',
    sifones: 'Sifones',
    sopapas: 'Sopapas',
    roller: 'Roller / Escurridor',
    asadera: 'Asadera',
    otros: 'Otros Accesorios',
  };

  const installationLabels: Record<string, string> = {
    'sobre-mueble': 'Sobre Mueble',
    'bajo-mesada': 'Bajo Mesada',
    empotrar: 'Empotrar',
    colgar: 'Colgar',
    'sobre-mesada-bajo-mesada': 'Sobre/Bajo Mesada',
  };

  const widthRangeLabels: Record<string, string> = {
    'under-60': 'Ancho: < 60 cm',
    '60-79': 'Ancho: 60-79 cm',
    '80-119': 'Ancho: 80-119 cm',
    '120-159': 'Ancho: 120-159 cm',
    'over-160': 'Ancho: ≥ 160 cm',
  };

  // DOM Elements
  const checkboxes = document.querySelectorAll('.filter-checkbox:not(.main-category-checkbox)');
  const items = document.querySelectorAll('.catalog__item');
  const emptyFiltered = document.getElementById('catalog-empty-filtered');
  const activeFiltersSection = document.getElementById('active-filters-section');
  const activeChipsContainer = document.getElementById('active-chips-container');
  const clearAllBtn = document.getElementById('clear-all-btn');
  const emptyResetBtn = document.getElementById('empty-reset-btn');

  // Mobile Drawer elements
  const mobileBtn = document.getElementById('mobile-filters-btn');
  const sidebar = document.getElementById('catalog-sidebar');
  const closeBtn = document.getElementById('sidebar-close-btn');
  const backdrop = document.getElementById('sidebar-backdrop');

  // Drawer handlers
  function openSidebar() {
    sidebar?.classList.add('is-open');
    backdrop?.classList.add('is-open');
    mobileBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    sidebar?.classList.remove('is-open');
    backdrop?.classList.remove('is-open');
    mobileBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  if (mobileBtn && sidebar) {
    mobileBtn.addEventListener('click', openSidebar);
    closeBtn?.addEventListener('click', closeSidebar);
    backdrop?.addEventListener('click', closeSidebar);
  }

  // Collapsible sections logic
  const headers = document.querySelectorAll('.filter-section__header');
  headers.forEach((header) => {
    header.addEventListener('click', () => {
      const section = header.parentElement;
      const isExpanded = header.getAttribute('aria-expanded') === 'true';
      header.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
      section?.classList.toggle('collapsed');
    });
  });

  // Filter Engine
  function applyFilters() {
    let visibleCount = 0;
    let matchedItems: HTMLElement[] = [];
    const searchInput = document.getElementById('catalog-search') as HTMLInputElement;
    const query = searchInput?.value.toLowerCase().trim() || '';

    items.forEach((item) => {
      const line = item.getAttribute('data-line') || '';
      const subcategory = item.getAttribute('data-subcategory') || '';
      const thickness = item.getAttribute('data-thickness') || '';
      const installation = item.getAttribute('data-installation') || '';
      const widthRange = item.getAttribute('data-width-range') || '';
      const name = item.getAttribute('data-name') || '';
      const description = item.getAttribute('data-description') || '';

      const matchLine =
        currentFilters.line.length === 0 || currentFilters.line.includes(line);
      const matchCategory =
        currentFilters.category.length === 0 || currentFilters.category.includes(subcategory);
      const matchThickness =
        currentFilters.thickness.length === 0 || currentFilters.thickness.includes(thickness);
      const matchInstallation =
        currentFilters.installationType.length === 0 || currentFilters.installationType.includes(installation);
      const matchWidthRange =
        currentFilters.widthRange.length === 0 || currentFilters.widthRange.includes(widthRange);
      const matchSearch =
        query === '' ||
        name.includes(query) ||
        description.includes(query);

      const passesFilter =
        matchLine && matchCategory && matchThickness && matchInstallation && matchWidthRange && matchSearch;
      const el = item as HTMLElement;

      if (passesFilter) {
        matchedItems.push(el);
      } else {
        el.style.display = 'none';
        el.style.animation = '';
      }
    });

    // Apply pagination to matched items
    matchedItems.forEach((el, idx) => {
      if (idx < visibleLimit) {
        el.style.display = '';
        el.style.animation = 'catalogReveal 0.4s var(--ease-out-expo) forwards';
        visibleCount++;
      } else {
        el.style.display = 'none';
        el.style.animation = '';
      }
    });

    // Update "load more" button
    const loadMoreWrapper = document.getElementById('load-more-wrapper');
    const loadMoreLabel = document.getElementById('load-more-label');
    const loadMoreCount = document.getElementById('load-more-count');
    const remaining = matchedItems.length - visibleLimit;
    if (loadMoreWrapper) {
      if (remaining > 0) {
        loadMoreWrapper.style.display = 'flex';
        if (loadMoreLabel) loadMoreLabel.textContent = 'Ver más productos';
        if (loadMoreCount) loadMoreCount.textContent = `Mostrando ${Math.min(visibleLimit, matchedItems.length)} de ${matchedItems.length} productos`;
      } else {
        loadMoreWrapper.style.display = matchedItems.length > PAGE_SIZE ? 'flex' : 'none';
        if (remaining <= 0 && matchedItems.length > PAGE_SIZE) {
          if (loadMoreLabel) loadMoreLabel.textContent = 'Ver menos';
          if (loadMoreCount) loadMoreCount.textContent = `Mostrando todos los ${matchedItems.length} productos`;
        }
      }
    }

    // Update empty state
    const totalVisible = matchedItems.length;
    if (emptyFiltered) {
      emptyFiltered.style.display =
        totalVisible === 0 && items.length > 0 ? 'flex' : 'none';
    }

    updateUI();
    saveFilters();
  }

  function saveFilters() {
    const searchInput = document.getElementById('catalog-search') as HTMLInputElement;
    const state = {
      filters: currentFilters,
      search: searchInput?.value || ''
    };
    sessionStorage.setItem('masecorFilters', JSON.stringify(state));
  }

  function updateUI() {
    // 1. Sync checkbox states with currentFilters
    checkboxes.forEach((cb) => {
      const input = cb as HTMLInputElement;
      const type = input.getAttribute('data-filter-type');
      const val = input.value;

      if (type && currentFilters[type]) {
        input.checked = currentFilters[type].includes(val);
      }
    });

    // 2. Sync main category parent checkboxes based on their children (including indeterminate state)
    const mainCheckboxes = document.querySelectorAll('.main-category-checkbox');
    mainCheckboxes.forEach((mcb) => {
      const mainInput = mcb as HTMLInputElement;
      const mainCat = mainInput.value;
      const children = document.querySelectorAll(`.sub-category-checkbox[data-parent-category="${mainCat}"]`);
      if (children.length > 0) {
        const childrenArray = Array.from(children) as HTMLInputElement[];
        const checkedCount = childrenArray.filter((child) => child.checked).length;
        
        if (checkedCount === childrenArray.length) {
          mainInput.checked = true;
          mainInput.indeterminate = false;
        } else if (checkedCount > 0) {
          mainInput.checked = false;
          mainInput.indeterminate = true;
        } else {
          mainInput.checked = false;
          mainInput.indeterminate = false;
        }
      }
    });

    // 3. Render active filter chips at the top
    if (activeChipsContainer && activeFiltersSection) {
      activeChipsContainer.innerHTML = '';
      let activeCount = 0;

      Object.entries(currentFilters).forEach(([type, values]) => {
        values.forEach((value) => {
          activeCount++;
          let label = value;
          if (type === 'line') label = lineLabels[value] || value;
          if (type === 'category') label = subCategoryLabels[value] || value;
          if (type === 'installationType')
            label = installationLabels[value] || value;
          if (type === 'widthRange')
            label = widthRangeLabels[value] || value;

          const chip = document.createElement('button');
          chip.className = 'active-chip';
          chip.innerHTML = `
            <span>${label}</span>
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          `;

          chip.addEventListener('click', () => {
            currentFilters[type] = currentFilters[type].filter((v) => v !== value);
            applyFilters();
          });

          activeChipsContainer.appendChild(chip);
        });
      });

      activeFiltersSection.style.display = activeCount > 0 ? 'block' : 'none';
    }
  }

  // Bind change handlers to checkboxes
  checkboxes.forEach((cb) => {
    cb.addEventListener('change', () => {
      const input = cb as HTMLInputElement;
      const type = input.getAttribute('data-filter-type');
      const val = input.value;

      if (type && currentFilters[type]) {
        if (input.checked) {
          if (!currentFilters[type].includes(val)) {
            currentFilters[type].push(val);
          }
        } else {
          currentFilters[type] = currentFilters[type].filter((v) => v !== val);
        }
        visibleLimit = PAGE_SIZE; // reset pagination on filter change
        applyFilters();
      }
    });
  });

  // Bind change handlers to main category checkboxes
  const mainCategoryCheckboxes = document.querySelectorAll('.main-category-checkbox');
  mainCategoryCheckboxes.forEach((mcb) => {
    mcb.addEventListener('change', () => {
      const input = mcb as HTMLInputElement;
      const mainCat = input.value;
      const isChecked = input.checked;

      const children = document.querySelectorAll(`.sub-category-checkbox[data-parent-category="${mainCat}"]`);
      children.forEach((child) => {
        const childInput = child as HTMLInputElement;
        const val = childInput.value;

        if (isChecked) {
          if (!currentFilters.category.includes(val)) {
            currentFilters.category.push(val);
          }
        } else {
          currentFilters.category = currentFilters.category.filter((v) => v !== val);
        }
      });
      applyFilters();
    });
  });

  // Reset all handler
  function resetAll() {
    Object.keys(currentFilters).forEach((key) => {
      currentFilters[key] = [];
    });
    const searchInput = document.getElementById('catalog-search') as HTMLInputElement;
    if (searchInput) {
      searchInput.value = '';
    }
    visibleLimit = PAGE_SIZE; // reset pagination
    applyFilters();
  }

  clearAllBtn?.addEventListener('click', resetAll);
  emptyResetBtn?.addEventListener('click', resetAll);

  // Search input change listener
  const searchInput = document.getElementById('catalog-search') as HTMLInputElement;
  searchInput?.addEventListener('input', () => {
    visibleLimit = PAGE_SIZE; // reset pagination on new search
    applyFilters();
  });

  // Bind click handlers to "Ver Solo" buttons next to main categories
  const onlyButtons = document.querySelectorAll('.filter-only-btn');
  onlyButtons.forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const mainCat = btn.getAttribute('data-main-category');
      if (mainCat) {
        // Clear all subcategory filters
        currentFilters.category = [];
        // Add all subcategories under this main category
        const children = document.querySelectorAll(`.sub-category-checkbox[data-parent-category="${mainCat}"]`);
        children.forEach((child) => {
          const childInput = child as HTMLInputElement;
          currentFilters.category.push(childInput.value);
        });
        visibleLimit = PAGE_SIZE; // reset pagination
        applyFilters();
      }
    });
  });

  // Load more button handler
  const loadMoreBtn = document.getElementById('load-more-btn');
  const loadMoreLabel = document.getElementById('load-more-label');
  loadMoreBtn?.addEventListener('click', () => {
    if (loadMoreLabel?.textContent?.includes('menos')) {
      // Collapse back to initial page
      visibleLimit = PAGE_SIZE;
    } else {
      // Expand by one page
      visibleLimit += PAGE_SIZE;
    }
    applyFilters();
    // Smooth scroll hint - only scroll if we expanded
    if (!loadMoreLabel?.textContent?.includes('menos')) {
      const grid = document.getElementById('product-grid');
      if (grid) {
        const lastVisible = Array.from(grid.querySelectorAll('.catalog__item')).filter(
          (el) => (el as HTMLElement).style.display !== 'none'
        ).pop();
        lastVisible?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    }
  });

  // Load filters from session storage on initial render
  function loadFilters() {
    let hadSavedFilters = false;
    try {
      const saved = sessionStorage.getItem('masecorFilters');
      if (saved) {
        const state = JSON.parse(saved);
        if (state.filters) {
          Object.assign(currentFilters, state.filters);
        }
        if (state.search && searchInput) {
          searchInput.value = state.search;
        }
        // Check if any filter was actually active
        const hasActiveFilters = Object.values(currentFilters).some((arr) => arr.length > 0);
        const hasSearch = searchInput?.value?.trim() !== '';
        hadSavedFilters = hasActiveFilters || hasSearch;
      }
    } catch (e) {
      console.error('Error loading filters from session storage', e);
    }
    // Always apply filters on load to enforce pagination
    applyFilters();

    // If we restored filters (user came back from a product page), scroll to the catalog grid
    if (hadSavedFilters) {
      requestAnimationFrame(() => {
        const catalog = document.querySelector('.catalog');
        if (catalog) {
          const offset = 100; // leave some space above for the navbar
          const top = catalog.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
    }
  }

  // Use Astro's astro:page-load event to ensure script runs on client navigation
  document.addEventListener('astro:page-load', loadFilters, { once: true });
  // Also run immediately in case astro:page-load already fired or is not used
  loadFilters();
</script>

