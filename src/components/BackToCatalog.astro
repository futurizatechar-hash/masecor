---
/**
 * BackToCatalog component — Masecor Web
 *
 * Renders a consistent 'Volver al catálogo' link at the end of the page.
 */
---
<div class="container back-catalog-container">
  <div class="back-catalog-wrapper" data-reveal>
    <a href="/productos" class="back-catalog-link">
      ← Volver al catálogo
    </a>
  </div>
</div>

<style>
  .back-catalog-container {
    padding-bottom: var(--space-12);
    margin-top: var(--space-8);
    width: 100%;
  }

  .back-catalog-wrapper {
    padding-top: var(--space-6);
    border-top: 1px solid rgba(128, 128, 128, 0.2);
  }

  .back-catalog-link {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--gray-500);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .back-catalog-link:hover {
    color: var(--black-rich);
    text-decoration: underline;
  }
</style>
